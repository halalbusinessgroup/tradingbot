# --- Database ---
DATABASE_URL=postgresql://trader:traderpass@postgres:5432/tradingbot
REDIS_URL=redis://redis:6379/0

# --- Security ---
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
AES_KEY=CHANGE_ME_TO_FERNET_KEY

# --- Binance ---
BINANCE_TESTNET=true

# --- Bybit ---
BYBIT_TESTNET=true

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_BOT_USERNAME=YourBotUsername

# --- Admin ---
ADMIN_EMAIL=admin@mytradingbot.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# --- App ---
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# --- Email (for verification codes) ---
# Gmail: enable 2FA → App Passwords → generate password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your@gmail.com
